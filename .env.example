# MELE root environment example
# Copy values into the correct platform, but do not commit real secrets.

# Web frontend: Vercel or apps/web/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_LIFF_ID=your-line-liff-id
NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN=false
NEXT_PUBLIC_ENABLE_LINE_LOGIN=false
NEXT_PUBLIC_LINE_OAUTH_PROVIDER=custom:line
NEXT_PUBLIC_ENABLE_FREE_BOOKING_TEST_MODE=false
MELE_API_URL=https://your-python-api-domain.com

# Python FastAPI service: Railway, Render, Fly.io, VM, or Docker host
PYTHONPATH=python_api
MELE_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:3000,http://127.0.0.1:3006
MELE_RATE_LIMIT_PER_MINUTE=60
MELE_HEAVY_MAX_CONCURRENCY=4

# Supabase Edge Function secrets.
# Set these with `supabase secrets set ...`; never expose them in frontend code.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=never-put-this-in-next-public-env
MELE_WEB_URL=https://your-domain.com

# ECPay sandbox first, then production after a complete payment test.
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=your-ecpay-hash-key
ECPAY_HASH_IV=your-ecpay-hash-iv
ECPAY_CHECKOUT_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5
ECPAY_RETURN_URL=https://your-project-ref.functions.supabase.co/ecpay-webhook
ECPAY_CLIENT_BACK_URL=https://your-domain.com/account/payment/result

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
